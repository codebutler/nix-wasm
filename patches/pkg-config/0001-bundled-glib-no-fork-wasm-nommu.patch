--- a/glib/glib/gspawn.c	2026-06-21 15:01:09.590238387 -0400
+++ b/glib/glib/gspawn.c	2026-06-21 15:03:11.807194827 -0400
@@ -1332,6 +1332,17 @@
   if (standard_error && !make_pipe (stderr_pipe, error))
     goto cleanup_and_fail;
 
+#ifdef __wasm__
+  /* wasm NOMMU: no fork/vfork.  g_spawn is not called by pkg-config at
+   * runtime (it only reads .pc files), but the glib bundled in pkg-config
+   * 0.29.2 does not have the posix_spawn codepath.  Fail loudly here so
+   * no fork symbol is referenced and any accidental spawn call is caught. */
+  g_set_error (error, G_SPAWN_ERROR, G_SPAWN_ERROR_FAILED,
+               "g_spawn: fork() is not available on wasm NOMMU");
+  goto cleanup_and_fail;
+#endif /* __wasm__ */
+
+#ifndef __wasm__ /* fork()/vfork() do not exist on wasm NOMMU; wasm exits above */
   pid = fork ();
 
   if (pid < 0)
@@ -1578,6 +1589,7 @@
       
       return TRUE;
     }
+#endif /* !__wasm__ */
 
  cleanup_and_fail:
 
