diff --git a/drivers/tty/hvc/hvc_wasm.c b/drivers/tty/hvc/hvc_wasm.c
index 060fb27..680a27e 100644
--- a/drivers/tty/hvc/hvc_wasm.c
+++ b/drivers/tty/hvc/hvc_wasm.c
@@ -4,6 +4,18 @@
 
 extern ssize_t wasm_driver_hvc_put(uint32_t vtermno, const u8 *buf, size_t count);
 extern ssize_t wasm_driver_hvc_get(uint32_t vtermno, u8 *buf, size_t count);
+/* pc (ticket #74, TIOCSWINSZ): host-reported window size for a console,
+ * packed (rows<<16)|cols (0 = unset). */
+extern u32 wasm_driver_hvc_winsize(uint32_t vtermno);
+
+/* pc (ticket #74, multi-tty): register HVC_WASM_NR_CONSOLES hvc lines so
+ * several terminals share one kernel — one /dev/hvcN per window. MUST match
+ * js/linux/boot.js HVC_CONSOLES and pc-init's inittab. hvc0 is also the boot
+ * console. */
+#define HVC_WASM_NR_CONSOLES 8
+
+static struct hvc_struct *hvc_wasm_hp[HVC_WASM_NR_CONSOLES];
+static u32 hvc_wasm_last_ws[HVC_WASM_NR_CONSOLES];
 
 static ssize_t hvc_wasm_put_chars(uint32_t vtermno, const u8 *buf, size_t count)
 {
@@ -12,6 +24,20 @@ static ssize_t hvc_wasm_put_chars(uint32_t vtermno, const u8 *buf, size_t count)
 
 static ssize_t hvc_wasm_get_chars(uint32_t vtermno, u8 *buf, size_t count)
 {
+	/* TIOCSWINSZ: poll the host window size and resize the tty when it
+	 * changes. get_chars runs under hp->lock, so __hvc_resize (the
+	 * lock-held variant) is safe here. */
+	if (vtermno < HVC_WASM_NR_CONSOLES && hvc_wasm_hp[vtermno]) {
+		u32 ws = wasm_driver_hvc_winsize(vtermno);
+
+		if (ws && ws != hvc_wasm_last_ws[vtermno]) {
+			struct winsize w = { .ws_row = ws >> 16, .ws_col = ws & 0xffff };
+
+			hvc_wasm_last_ws[vtermno] = ws;
+			__hvc_resize(hvc_wasm_hp[vtermno], w);
+		}
+	}
+
 	return wasm_driver_hvc_get(vtermno, buf, count);
 }
 
@@ -20,20 +46,16 @@ static const struct hv_ops hvc_wasm_ops = {
 	.put_chars = hvc_wasm_put_chars,
 };
 
-/* pc (ticket #74, multi-tty): register HVC_WASM_NR_CONSOLES hvc lines so several
- * terminals can share one kernel — one /dev/hvcN per window. MUST match
- * js/linux/boot.js HVC_CONSOLES and pc-init's inittab. hvc0 is also the boot
- * console. */
-#define HVC_WASM_NR_CONSOLES 8
-
 static int __init hvc_wasm_init(void)
 {
-	int i, ret;
+	int i;
 
 	for (i = 0; i < HVC_WASM_NR_CONSOLES; i++) {
-		ret = PTR_ERR_OR_ZERO(hvc_alloc(i, i, &hvc_wasm_ops, PAGE_SIZE));
-		if (ret)
-			return ret;
+		struct hvc_struct *hp = hvc_alloc(i, i, &hvc_wasm_ops, PAGE_SIZE);
+
+		if (IS_ERR(hp))
+			return PTR_ERR(hp);
+		hvc_wasm_hp[i] = hp;
 	}
 
 	return 0;
