diff --git a/arch/wasm/mm/user_as.c b/arch/wasm/mm/user_as.c
new file mode 100644
index 000000000..b6b7e0ce9
--- /dev/null
+++ b/arch/wasm/mm/user_as.c
@@ -0,0 +1,374 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Per-`mm` base-0 user-address-space allocator (Task 2).
+ *
+ * Each user process gets a distinct base-0 WebAssembly.Memory (runtime-owned,
+ * pid-keyed; minted by wasm_user_mem_create). This file is the kernel-side
+ * bump/free-list allocator that hands out offsets into that private space; the
+ * small offsets it returns flow to the runtime as __memory_base/__stack_pointer
+ * exactly as the shared-pool addresses do today, but index the PRIVATE memory
+ * once T2.3 flips instantiation.
+ *
+ * Landed DARK: gated behind the `wasm_user_as` early-param (default off). With
+ * the flag off, wasm_user_as_active() is false everywhere and mm/nommu.c takes
+ * the legacy shared alloc_pages_exact path → default boot is unchanged. With the
+ * flag on, a boot-time self-test exercises the allocator math (the only proof
+ * possible before T2.3 wires the private memory into instantiation).
+ *
+ * Page accounting: the runtime grows the private memory in WASM pages
+ * (WASM_PAGE_SIZE = 64 KiB), which is independent of the kernel's PAGE_SIZE.
+ * Offsets are PAGE_SIZE-aligned (kernel page granularity); the private memory
+ * SIZE and the grow delta are tracked in WASM pages.
+ */
+#include <linux/init.h>
+#include <linux/kernel.h>
+#include <linux/string.h>
+#include <linux/slab.h>
+#include <linux/list.h>
+#include <linux/mm.h>
+#include <linux/mm_types.h>
+#include <linux/printk.h>
+#include <linux/sched.h>
+#include <linux/pid.h>
+#include <asm/page.h>
+#include <asm/mmu.h>
+#include <asm/user_as.h>
+#include <asm/wasm.h>
+
+bool wasm_user_as_enabled __ro_after_init;
+
+static int __init wasm_user_as_setup(char *str)
+{
+	if (!str || !strcmp(str, "1") || !strcmp(str, "on") || !strcmp(str, "y"))
+		wasm_user_as_enabled = true;
+	return 0;
+}
+early_param("wasm_user_as", wasm_user_as_setup);
+
+/* A freed extent on mm->context.user_as_free (offsets into the private space). */
+struct user_as_extent {
+	struct list_head list;
+	unsigned long start;	/* offset, page-aligned */
+	unsigned long len;	/* bytes, page-aligned */
+};
+
+static int wasm_user_as_pid(void)
+{
+	struct task_struct *t = current;
+
+	return t ? task_pid_nr(t) : 0;
+}
+
+int wasm_user_as_init(struct mm_struct *mm, unsigned long size_bytes)
+{
+	/* Round the private size up to a whole number of wasm pages. */
+	mm->context.user_as_size = ALIGN(size_bytes, WASM_PAGE_SIZE);
+	mm->context.user_as_brk = USER_AS_BASE;
+	INIT_LIST_HEAD(&mm->context.user_as_free);
+	mm->context.user_as_live = true;
+	return 0;
+}
+
+/*
+ * First-fit the free-list. On an exact-or-larger hit, carve `len` off the FRONT
+ * of the extent (so callers get the lowest offset; the tail stays free).
+ */
+static unsigned long alloc_from_freelist(struct mm_struct *mm, unsigned long len)
+{
+	struct user_as_extent *e;
+
+	list_for_each_entry(e, &mm->context.user_as_free, list) {
+		if (e->len >= len) {
+			unsigned long base = e->start;
+
+			if (e->len == len) {
+				list_del(&e->list);
+				kfree(e);
+			} else {
+				e->start += len;
+				e->len -= len;
+			}
+			return base;
+		}
+	}
+	return 0;
+}
+
+unsigned long wasm_user_as_alloc(struct mm_struct *mm, unsigned long len)
+{
+	unsigned long base, need_end, have, want, delta_pages, grown;
+
+	len = PAGE_ALIGN(len);
+	if (!len)
+		return 0;
+
+	/* Reuse a freed extent first (munmap reuse). */
+	base = alloc_from_freelist(mm, len);
+	if (base)
+		return base;
+
+	/* Else bump from the brk. */
+	base = mm->context.user_as_brk;
+	need_end = base + len;
+	if (need_end < base) /* overflow */
+		return 0;
+
+	/* Grow the private memory if the bump would overflow it. */
+	have = mm->context.user_as_size;
+	if (need_end > have) {
+		want = ALIGN(need_end - have, WASM_PAGE_SIZE);
+		delta_pages = want / WASM_PAGE_SIZE;	/* runtime grows in wasm pages */
+		grown = wasm_user_mem_grow(wasm_user_as_pid(), delta_pages);
+		if (grown == (unsigned long)-1)
+			return 0;
+		mm->context.user_as_size = grown * WASM_PAGE_SIZE;
+		if (need_end > mm->context.user_as_size)
+			return 0;
+	}
+
+	mm->context.user_as_brk = need_end;
+	return base;
+}
+
+/* Coalesce-insert [base,base+len) into the (address-ordered) free-list. */
+void wasm_user_as_free_extent(struct mm_struct *mm, unsigned long base,
+			      unsigned long len)
+{
+	struct user_as_extent *e, *prev = NULL, *ne;
+	unsigned long end;
+
+	len = PAGE_ALIGN(len);
+	if (!len)
+		return;
+	end = base + len;
+
+	/* If it abuts the bump pointer, just retract the brk (never shrink mem). */
+	if (end == mm->context.user_as_brk) {
+		mm->context.user_as_brk = base;
+		/* Pull back any freed extents now adjacent to the new brk. */
+again:
+		list_for_each_entry(e, &mm->context.user_as_free, list) {
+			if (e->start + e->len == mm->context.user_as_brk) {
+				mm->context.user_as_brk = e->start;
+				list_del(&e->list);
+				kfree(e);
+				goto again;
+			}
+		}
+		return;
+	}
+
+	/* Insert in address order, coalescing with neighbours. */
+	list_for_each_entry(e, &mm->context.user_as_free, list) {
+		if (e->start > base)
+			break;
+		prev = e;
+	}
+
+	/* Coalesce with prev (prev.end == base). */
+	if (prev && prev->start + prev->len == base) {
+		prev->len += len;
+		/* Maybe now also abuts the following extent. */
+		if (!list_is_last(&prev->list, &mm->context.user_as_free)) {
+			struct user_as_extent *next = list_next_entry(prev, list);
+
+			if (prev->start + prev->len == next->start) {
+				prev->len += next->len;
+				list_del(&next->list);
+				kfree(next);
+			}
+		}
+		return;
+	}
+
+	ne = kmalloc(sizeof(*ne), GFP_KERNEL);
+	if (!ne) {
+		/* Leak the extent rather than corrupt; grow-only engine tolerates it. */
+		pr_warn("wasm_user_as: free-list OOM, leaking [0x%lx,+0x%lx)\n",
+			base, len);
+		return;
+	}
+	ne->start = base;
+	ne->len = len;
+	if (prev)
+		list_add(&ne->list, &prev->list);
+	else
+		list_add(&ne->list, &mm->context.user_as_free);
+
+	/* Coalesce forward with the following extent (ne.end == next.start). */
+	if (!list_is_last(&ne->list, &mm->context.user_as_free)) {
+		struct user_as_extent *next = list_next_entry(ne, list);
+
+		if (ne->start + ne->len == next->start) {
+			ne->len += next->len;
+			list_del(&next->list);
+			kfree(next);
+		}
+	}
+}
+
+void wasm_user_as_memzero(struct mm_struct *mm, unsigned long uaddr,
+			  unsigned long n)
+{
+	/*
+	 * pid resolved via `current`; the `mm` param is reserved/unused — the
+	 * host-bridge always targets `current`'s address space (registry model R1:
+	 * uaccess only ever targets current). Do NOT assume this zeroes a non-current
+	 * mm's private memory — it does not.
+	 */
+	(void)mm;
+	wasm_user_memzero(wasm_user_as_pid(), uaddr, n);
+}
+
+void wasm_user_as_destroy(struct mm_struct *mm)
+{
+	struct user_as_extent *e, *tmp;
+
+	if (!mm->context.user_as_live)
+		return;
+
+	list_for_each_entry_safe(e, tmp, &mm->context.user_as_free, list) {
+		list_del(&e->list);
+		kfree(e);
+	}
+	mm->context.user_as_live = false;
+	mm->context.user_as_brk = 0;
+	mm->context.user_as_size = 0;
+
+	wasm_user_mem_free(wasm_user_as_pid());
+}
+
+/* Count freed extents currently on the list (self-test helper). */
+static unsigned long selftest_freelist_count(struct mm_struct *mm)
+{
+	struct user_as_extent *e;
+	unsigned long n = 0;
+
+	list_for_each_entry(e, &mm->context.user_as_free, list)
+		n++;
+	return n;
+}
+
+static void selftest_drain(struct mm_struct *mm)
+{
+	struct user_as_extent *e, *tmp;
+
+	list_for_each_entry_safe(e, tmp, &mm->context.user_as_free, list) {
+		list_del(&e->list);
+		kfree(e);
+	}
+}
+
+/*
+ * Boot-time self-test (flag-on only): exercises the bump/free-list math on a
+ * throwaway mm_context with no runtime memory. Proves the allocator hands out
+ * offsets in [USER_AS_BASE, size), first-fit reuse, ADJACENT-extent coalescing,
+ * the brk-retract reclaim (`again` loop), and the overflow→grow path (which
+ * fails closed here since the fake mm has no runtime memory) — the honest
+ * dark-mode verification (a running process over private memory is T2.3). The
+ * free path got the most scrutiny because the T2.2 review found a Critical
+ * there, so it is the most heavily covered below.
+ */
+static int __init wasm_user_as_selftest(void)
+{
+	struct mm_struct fake = {};
+	unsigned long a, b, c, d, first;
+
+	if (!wasm_user_as_enabled)
+		return 0;
+
+	fake.context.user_as_size = 64UL << 20; /* 64 MiB pretend space */
+	fake.context.user_as_brk = USER_AS_BASE;
+	INIT_LIST_HEAD(&fake.context.user_as_free);
+	fake.context.user_as_live = true;
+
+	/* 1. Bump: monotonic offsets in [USER_AS_BASE, size). */
+	a = wasm_user_as_alloc(&fake, PAGE_SIZE);		/* [A,   1pg] */
+	first = a;
+	b = wasm_user_as_alloc(&fake, 2 * PAGE_SIZE);		/* [B,   2pg] */
+	c = wasm_user_as_alloc(&fake, PAGE_SIZE);		/* [C,   1pg] */
+	d = wasm_user_as_alloc(&fake, PAGE_SIZE);		/* [D,   1pg] */
+	if (a < USER_AS_BASE || b != a + PAGE_SIZE ||
+	    c != b + 2 * PAGE_SIZE || d != c + PAGE_SIZE ||
+	    d >= fake.context.user_as_size) {
+		pr_err("WASM_USER_AS_SELFTEST: FAIL bump a=0x%lx b=0x%lx c=0x%lx d=0x%lx\n",
+		       a, b, c, d);
+		goto fail;
+	}
+
+	/* 2. First-fit reuse: free B, re-alloc same size → must reuse B. */
+	wasm_user_as_free_extent(&fake, b, 2 * PAGE_SIZE);
+	if (wasm_user_as_alloc(&fake, 2 * PAGE_SIZE) != b) {
+		pr_err("WASM_USER_AS_SELFTEST: FAIL first-fit reuse\n");
+		goto fail;
+	}
+
+	/* 3. Adjacent-extent COALESCE (self-contained): A..D 1pg each; free B then C
+	 *    (B.end == C.start, neither abuts brk). They must merge into ONE
+	 *    free-list entry spanning [B, 2pg) which a 2pg alloc then reuses at B. */
+	selftest_drain(&fake);
+	fake.context.user_as_brk = USER_AS_BASE;
+	a = wasm_user_as_alloc(&fake, PAGE_SIZE);
+	b = wasm_user_as_alloc(&fake, PAGE_SIZE);
+	c = wasm_user_as_alloc(&fake, PAGE_SIZE);
+	d = wasm_user_as_alloc(&fake, PAGE_SIZE);	/* keeps B,C off the brk */
+	wasm_user_as_free_extent(&fake, b, PAGE_SIZE);
+	wasm_user_as_free_extent(&fake, c, PAGE_SIZE);
+	if (selftest_freelist_count(&fake) != 1) {
+		pr_err("WASM_USER_AS_SELFTEST: FAIL coalesce count=%lu\n",
+		       selftest_freelist_count(&fake));
+		goto fail;
+	}
+	if (wasm_user_as_alloc(&fake, 2 * PAGE_SIZE) != b) {
+		pr_err("WASM_USER_AS_SELFTEST: FAIL coalesced reuse\n");
+		goto fail;
+	}
+	(void)a;
+	(void)d;
+
+	/* 4. brk-retract reclaim (`again` loop): alloc A..D, free C first (lands on
+	 *    the free-list, NOT abutting brk), then free D (abuts brk → brk retracts
+	 *    to C.end, and the `again` loop must then find the freed C extent now
+	 *    adjacent to the retracted brk and reclaim it too). Result: free-list
+	 *    empty and brk == C. */
+	selftest_drain(&fake);
+	fake.context.user_as_brk = USER_AS_BASE;
+	a = wasm_user_as_alloc(&fake, PAGE_SIZE);
+	b = wasm_user_as_alloc(&fake, PAGE_SIZE);
+	c = wasm_user_as_alloc(&fake, PAGE_SIZE);
+	d = wasm_user_as_alloc(&fake, PAGE_SIZE);	/* brk == d + 1pg */
+	wasm_user_as_free_extent(&fake, c, PAGE_SIZE);	/* not abutting brk → on list */
+	if (selftest_freelist_count(&fake) != 1) {
+		pr_err("WASM_USER_AS_SELFTEST: FAIL pre-retract list=%lu\n",
+		       selftest_freelist_count(&fake));
+		goto fail;
+	}
+	wasm_user_as_free_extent(&fake, d, PAGE_SIZE);	/* abuts brk → retract + reclaim C */
+	if (selftest_freelist_count(&fake) != 0 ||
+	    fake.context.user_as_brk != c) {
+		pr_err("WASM_USER_AS_SELFTEST: FAIL brk-retract brk=0x%lx free=%lu (c=0x%lx)\n",
+		       fake.context.user_as_brk, selftest_freelist_count(&fake), c);
+		goto fail;
+	}
+	(void)a;
+	(void)b;
+
+	/* 5. Overflow → grow: shrink the pretend size so the next bump overflows.
+	 *    With no runtime memory, wasm_user_mem_grow returns -1, so the alloc
+	 *    MUST fail closed (return 0) rather than hand out an out-of-range offset.
+	 *    (A SUCCESSFUL grow needs a real per-pid memory → proven in T2.3.) */
+	fake.context.user_as_size = fake.context.user_as_brk; /* no slack left */
+	if (wasm_user_as_alloc(&fake, PAGE_SIZE) != 0) {
+		pr_err("WASM_USER_AS_SELFTEST: FAIL overflow not rejected\n");
+		goto fail;
+	}
+
+	selftest_drain(&fake);
+	pr_info("WASM_USER_AS_SELFTEST: PASS first=0x%lx\n", first);
+	return 0;
+
+fail:
+	selftest_drain(&fake);
+	return 0;
+}
+late_initcall(wasm_user_as_selftest);
