From: nix-wasm <eric@codebutler.com>
Subject: [PATCH] wasm: transparent SA_RESTART via FOOT-level syscall restart loop (#75)

A blocking syscall interrupted by a signal whose handler was installed with
SA_RESTART (e.g. signal(), which musl maps to SA_RESTART) returns -ERESTARTSYS;
handle_signal() keeps it (will restart) and setup_rt_frame() queues the handler
(_TIF_DELIVER_SIGNAL). The handler only runs in the syscall asm FOOT
(_user_mode_tail), which executes AFTER __wasm_syscall_N returns; but the C
restart do/while in WASM_SYSCALL_N re-entered the syscall in-place on -ERESTARTSYS
and never returned to the FOOT, so the handler never ran and the syscall hung.
Headline symptom: busybox FANCY `ping` sent one ICMP echo then hung (its interval
SIGALRM handler sendping4, armed via signal(), never ran). `ping -c1` worked.

Restart-after-signal must run the handler BETWEEN the failed attempt and the
restart, and handler delivery only works at the FOOT context (top of the kernel
frame, C syscall frame popped, so the nested sigreturn syscall can reuse the
kernel stack) — calling _user_mode_tail from inside __wasm_syscall_N faults
(null function / signature mismatch -> panic). So the restart loop is lifted to
the asm FOOT:

  - traps.c: the C keeps its in-loop restart for the NO-handler cases (incl. the
    -ERESTART_RESTARTBLOCK -> __NR_restart_syscall nr-switch), unchanged. When a
    handler IS queued for a would-be restart, it stops looping and RETURNS with
    syscall_ret still holding the internal ERESTART code (-516..-512, which is
    never returned to userspace).
  - entry.S: each wasm_syscall_N now wraps `call __wasm_syscall_N` in a loop.
    After the call it runs WASM_SYSCALL_FOOT_SYNC (syncs user sp/tls from pt_regs
    and calls _user_mode_tail, delivering the queued handler + its sigreturn at
    the FOOT). If the saved return value is an ERESTART code, it re-establishes
    the kernel C-frame stack pointer (WASM_SYSCALL_RESET_SP) and branches back to
    re-run the syscall — so the restart happens AFTER the handler. Any other
    value is the real result and is returned.

Result: full transparent SA_RESTART. busybox ping's recv() runs sendping4 each
interval and returns real replies (no -EINTR); restartable syscalls restart and
return their real result exactly as on other arches. No host/engine ABI change
(the kernel<->engine import surface and __wasm_syscall_N signatures are
unchanged), so ENGINE_ABI is unchanged and no pc sync is needed.

--- a/arch/wasm/kernel/traps.c	2026-06-26 13:54:04.185612881 +0000
+++ b/arch/wasm/kernel/traps.c	2026-06-26 13:54:04.199580282 +0000
@@ -64,6 +64,17 @@
 				default:					\
 					restart = false;			\
 				}						\
+				/* #75: a signal handler queued for a would-be restart	\
+				 * must run BEFORE we restart, and it runs only at the	\
+				 * syscall asm FOOT after this function returns (calling	\
+				 * it here, mid-frame, faults). So leave the loop with	\
+				 * syscall_ret still holding the internal ERESTART code:	\
+				 * entry.S delivers the handler at the FOOT and re-invokes	\
+				 * us, so the restart happens AFTER the handler runs	\
+				 * (transparent SA_RESTART, no -EINTR to userspace). */	\
+				if (restart && (current_thread_info()->flags &		\
+					_TIF_DELIVER_SIGNAL))			\
+					restart = false;			\
 			} while (restart);					\
 		} else {							\
 			irqentry_state_t state = irqentry_nmi_enter(regs);	\

--- a/arch/wasm/kernel/entry.S	2026-06-26 13:54:11.165752249 +0000
+++ b/arch/wasm/kernel/entry.S	2026-06-26 13:54:11.167809888 +0000
@@ -156,7 +156,23 @@
 	 */
 .endm
 
-.macro WASM_SYSCALL_ASM_FOOT
+.macro WASM_SYSCALL_RESET_SP
+	/*
+	 * (Re)establish the kernel C-frame stack pointer before each syscall
+	 * attempt. WASM_SYSCALL_ASM_HEAD already did this for the first attempt;
+	 * the #75 restart loop re-runs it because WASM_SYSCALL_FOOT_SYNC moves
+	 * __stack_pointer to the top of the kernel stack for signal delivery.
+	 */
+	global.get current
+	iLONG.const zeroptr+TASK_STRUCT_STACK
+	iLONG.add
+	iLONG.load 0
+	iLONG.const zeroptr+THREAD_STACK_START
+	iLONG.add
+	global.set __stack_pointer
+.endm
+
+.macro WASM_SYSCALL_FOOT_SYNC
 	/* (The cpuflags have already been restored in C.) */
 
 	/*  __user_stack_pointer = current_pt_regs()->stack_pointer */
@@ -180,21 +196,12 @@
 	global.set __stack_pointer
 
 	/*
-	* Note: we don't need to swap the __stack_pointer, it will happen
-	* automatically when returning back into the user code Wasm instance (as
-	* that instance has its own __stack_pointer).
-	*
-	* We can exploit this as we're basically in userland, but with the
-	* kernel stack pointer loaded. This allows us to play tricks with
-	* execution in userland without setting a program counter.
-	*
-	* This is where signal handlers are called, and returned, and exec()
-	* calls stop the execution of the user program. In the case of exec()
-	* and signal return, the call stack collapses (this call never returns).
-	*/
+	 * Deliver any pending signal handler (and run its sigreturn) here at the
+	 * FOOT context: top of the kernel stack with the C syscall frame already
+	 * popped, so the nested sigreturn syscall can safely reuse the kernel
+	 * stack. (Calling this from inside __wasm_syscall_N faults — see #75.)
+	 */
 	call _user_mode_tail
-
-	end_function
 .endm
 
 .functype __wasm_syscall_0(iLONG) -> (iLONG)
@@ -227,76 +234,223 @@
 .globl wasm_syscall_0
 wasm_syscall_0:
 	.functype wasm_syscall_0(iLONG, iLONG, iLONG) -> (iLONG)
+	.local iLONG
 	WASM_SYSCALL_ASM_HEAD
-	local.get 2
-	call __wasm_syscall_0
-	WASM_SYSCALL_ASM_FOOT
+	loop
+		WASM_SYSCALL_RESET_SP
+		local.get 2
+		call __wasm_syscall_0
+		local.set 3
+		WASM_SYSCALL_FOOT_SYNC
+		/*
+		 * #75 transparent restart: __wasm_syscall_0 returns an internal
+		 * ERESTART code (-516..-512, never seen by userspace) ONLY when a
+		 * handler was queued for a restart; we just delivered it, so loop
+		 * back and re-run the syscall. Any other value is the real result.
+		 */
+		local.get 3
+		iLONG.const -512
+		iLONG.le_s
+		local.get 3
+		iLONG.const -516
+		iLONG.ge_s
+		i32.and
+		br_if 0
+	end_loop
+	local.get 3
+	end_function
 
