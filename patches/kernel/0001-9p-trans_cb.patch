diff --git a/net/9p/Kconfig b/net/9p/Kconfig
index 22f8c1678..48b553b0a 100644
--- a/net/9p/Kconfig
+++ b/net/9p/Kconfig
@@ -32,6 +32,16 @@ config NET_9P_VIRTIO
 	  This builds support for a transports between
 	  guest partitions and a host partition.
 
+config NET_9P_CB
+	bool "9P Wasm host-callback Transport"
+	default NET_9P
+	help
+	  This builds support for a 9P transport that issues requests to the
+	  JavaScript Wasm host via the wasm_driver_9p_request() callback. It is
+	  used by the "pc" desktop to mount its VFS into Linux/Wasm over 9P.
+
+	  Built-in only (Wasm cannot load modules). Say Y if unsure on Wasm.
+
 config NET_9P_XEN
 	depends on XEN
 	select XEN_XENBUS_FRONTEND
