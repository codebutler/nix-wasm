diff --git a/drivers/virtio/Kconfig b/drivers/virtio/Kconfig
index ce5bc0d9ea28..dbf7e5c496f6 100644
--- a/drivers/virtio/Kconfig
+++ b/drivers/virtio/Kconfig
@@ -171,6 +171,18 @@ config VIRTIO_MMIO_CMDLINE_DEVICES
 
 	 If unsure, say 'N'.
 
+config VIRTIO_WASM
+	bool "Wasm host-callback virtio transport (+ echo self-test)"
+	select VIRTIO
+	help
+	  Minimal virtio transport over Wasm host callbacks for Linux/Wasm
+	  ("pc" Wayland Phase 1). It registers a single test device and an
+	  in-kernel echo self-test driver that does a one-buffer virtqueue
+	  round-trip on boot, proving the guest<->host vring path and the
+	  host->guest used-buffer interrupt via raise_interrupt().
+
+	  Built-in only (Wasm cannot load modules). Say Y on Wasm if unsure.
+
 config VIRTIO_DMA_SHARED_BUFFER
 	tristate
 	depends on DMA_SHARED_BUFFER
