diff --git a/drivers/virtio/Kconfig b/drivers/virtio/Kconfig
index ce5bc0d..16fc74b 100644
--- a/drivers/virtio/Kconfig
+++ b/drivers/virtio/Kconfig
@@ -171,6 +171,41 @@ config VIRTIO_MMIO_CMDLINE_DEVICES
 
 	 If unsure, say 'N'.
 
+config VIRTIO_WASM
+	bool "Wasm host-callback virtio transport"
+	select VIRTIO
+	help
+	  Minimal virtio transport over Wasm host callbacks for Linux/Wasm
+	  ("pc" Wayland Phase 1). It registers virtio devices backed by a JS
+	  host device model: the split vring lives in the kernel's own memory
+	  and the JS host indexes it at the nommu identity offsets (the
+	  transport withholds VIRTIO_F_ACCESS_PLATFORM so virtio_ring takes
+	  the no-DMA path). Guest->host kicks go through wasm_virtio_notify();
+	  host->guest used-buffer interrupts come back via the guest's
+	  raise_interrupt() export.
+
+	  Built-in only (Wasm cannot load modules). Say Y on Wasm if unsure.
+
+config VIRTIO_WASM_ECHO
+	bool "Wasm virtio echo self-test"
+	depends on VIRTIO_WASM
+	help
+	  In-kernel echo self-test bound to a VIRTIO_WASM test device. On boot
+	  it does a two-virtqueue round-trip (proving multi-vq) and prints a
+	  RESULT virtio_wasm marker. Used by the Phase 1 1a/1b spikes; leave
+	  off in production builds.
+
+config VIRTIO_WL
+	bool "Virtio Wayland driver (virtwl, /dev/wl0)"
+	depends on VIRTIO_WASM
+	select VIRTIO
+	help
+	  Virtio Wayland (virtwl) exposes /dev/wl0, a misc char device that
+	  proxies the Wayland protocol between a guest client (via Sommelier)
+	  and a host compositor over two virtqueues. This is the ChromeOS
+	  virtio_wl driver, nommu-adapted for Linux/Wasm and bound to the
+	  VIRTIO_WASM transport (device id VIRTIO_ID_WL).
+
 config VIRTIO_DMA_SHARED_BUFFER
 	tristate
 	depends on DMA_SHARED_BUFFER
