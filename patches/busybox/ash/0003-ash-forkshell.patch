+	/* type of forkshell */
+	int fpid;
+
+	/* generic data, used by forkshell_child */
+	int mode;
+
+	/* optional data, used by forkshell_child */
+	int flags;
+	union node *n;
+	char **argv;
+	const char *path;
+};
