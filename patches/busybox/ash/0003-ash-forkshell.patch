+/* forkshell_pipeline (M6b): serialize each pipeline stage into its own
+ * forkshell block and hand the lot to the host, which runs every stage in a
+ * fresh child shell wired stage-to-stage with pipe queues. Returns the last
+ * stage's exit status (host), or raises on serialization/host failure. */
+static int
+forkshell_pipeline(union node *n, int flags)
+{
+	struct nodelist *lp;
+	int nstages = 0;
+	char *buf;
+	int cap, off, status;
+
+	for (lp = n->npipe.cmdlist; lp; lp = lp->next)
+		nstages++;
+
+	cap = 8192;
+	buf = ckmalloc(cap);
+	off = 4;
+	for (lp = n->npipe.cmdlist; lp; lp = lp->next) {
+		struct forkshell fs;
+		struct forkshell *blk;
+		int len;
+
+		memset(&fs, 0, sizeof(fs));
+		fs.fpid = FS_EVALPIPE;
+		fs.n = lp->n;
+		fs.flags = flags;
+		blk = forkshell_prepare(&fs);
+		len = forkshell_blocklen(blk);
+		while (off + 4 + len > cap) {
+			cap *= 2;
+			buf = ckrealloc(buf, cap);
+		}
+		buf[off+0] = (char)(len & 0xff);
+		buf[off+1] = (char)((len >> 8) & 0xff);
+		buf[off+2] = (char)((len >> 16) & 0xff);
+		buf[off+3] = (char)((len >> 24) & 0xff);
+		memcpy(buf + off + 4, blk, len);
+		off += 4 + len;
+		free(blk);
+	}
+	buf[0] = (char)(nstages & 0xff);
+	buf[1] = (char)((nstages >> 8) & 0xff);
+	buf[2] = (char)((nstages >> 16) & 0xff);
+	buf[3] = (char)((nstages >> 24) & 0xff);
+
+	status = __cb_fork_pipeline(buf, off, n->npipe.pipe_backgnd);
+	free(buf);
+	if (status < 0)
+		ash_msg_and_raise_error("can't fork");
+	return status;
+}
