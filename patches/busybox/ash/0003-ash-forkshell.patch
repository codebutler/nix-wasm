+/* ============ cb forkshell (M6, #106 items 1/2) — fork-without-exec.
+ *
+ * Port of busybox-w32's forkshell machinery (Windows also has no fork()) to
+ * the WASI build. ash forks WITHOUT exec'ing to run its own code in a child:
+ * subshells ( ... ), command substitution $(shell-code), backgrounded
+ * compound commands. wasm can't clone a live instance, so instead the parent
+ * SERIALIZES the state a child shell needs -- variables, functions, aliases,
+ * cmdtable, the parse-tree node to run -- into a flat block with a relocation
+ * bitmap (reusing ash's own copynode/calcsize machinery), and the cb host
+ * bridge boots a FRESH sh.wasm instance ("sh --fs") that fetches the block,
+ * relocates its pointers, installs the state, and evaluates the node. The
+ * child's stdio is wired by the host (terminal for subshells, a capture
+ * buffer for $(...)).
+ */
+
+union node;
+struct strlist;
+struct job;
+
+struct forkshell {
+	/* filled by forkshell_copy() */
+	struct globals_misc *gmp;
+	struct globals_var *gvp;
+	struct tblentry **cmdtable;
+#if ENABLE_ASH_ALIAS
+	struct alias **atab;
+#endif
+	char *old_base;     /* block address in the parent (relocation base) */
+	int size;           /* header + funcblock + funcstring, excl. bitmap */
