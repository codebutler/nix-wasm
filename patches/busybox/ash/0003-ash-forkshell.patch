+static struct forkshell *
+forkshell_prepare(struct forkshell *fs)
+{
+	struct forkshell *new;
+	struct datasize ds;
+	int size, relocatesize, bitmapsize;
+
+	/* calculate size of structure, funcblock and funcstring */
+	ds = forkshell_size(fs);
+	size = sizeof(struct forkshell) + ds.funcblocksize + ds.funcstringsize;
+	relocatesize = (sizeof(struct forkshell) + ds.funcblocksize)/sizeof(char *);
+	bitmapsize = (relocatesize + 7)/8;
+
+	new = ckzalloc(size + bitmapsize);
+
+	/* Initialise pointers */
+	fs_size = size;
+	fs_start = new;
+	funcblock = (char *)(new + 1);
+	funcstring_end = (char *)new + size;
+
+	/* Now pack them all */
+	forkshell_copy(fs, new);
+
+	/* Finish it up */
+	new->size = size;
+	new->relocatesize = relocatesize;
+	new->old_base = (char *)new;
+	fs_size = 0;
+	fs_start = NULL;
+	return new;
+}
+
+static int
+forkshell_blocklen(struct forkshell *blk)
+{
+	return blk->size + (blk->relocatesize + 7)/8;
+}
+
+static int
+forkshell_run(struct forkshell *fs, int bg)
+{
+	struct forkshell *blk = forkshell_prepare(fs);
+	int status;
+
+	status = __cb_fork_run((char *)blk, forkshell_blocklen(blk), bg);
+	free(blk);
+	if (status < 0)
+		ash_msg_and_raise_error("can't fork");
+	return status;
+}
+
+/* Max captured $(...) output. The host clamps to the SAB data region anyway
+ * (1 MiB); 256 KiB of command substitution is generous for a shell. */
+#define CB_FORK_CAPTURE_MAX (256*1024)
+
+static int
+forkshell_capture(struct forkshell *fs, char **bufp, int *statusp)
+{
+	struct forkshell *blk = forkshell_prepare(fs);
+	char *out;
+	int n;
+
+	*bufp = NULL;
+	out = ckmalloc(CB_FORK_CAPTURE_MAX);
+	n = __cb_fork_capture((char *)blk, forkshell_blocklen(blk),
+			      out, CB_FORK_CAPTURE_MAX, statusp);
+	free(blk);
+	if (n < 0) {
+		free(out);
+		return -1;
+	}
+	*bufp = out;
+	return n;
+}
