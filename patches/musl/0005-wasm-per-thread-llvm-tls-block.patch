+#ifdef __wasm__
+/* LLVM owns the wasm TLS segment (variables are addressed as
+ * __tls_base + offset; there is no PT_TLS, so libc.tls_cnt==0 and musl's
+ * generic TLS machinery knows nothing about it). Each new thread needs a
+ * real, initialized TLS block: we carve it out of the thread map just
+ * below the struct pthread (static_init_tls reserves the room), pass it
+ * as the clone TLS argument (the host runtime loads that into the child's
+ * __tls_base), and the child copies the TLS images in and points
+ * __musl_tp at its struct pthread before anything touches TLS. Without
+ * this, a child's __tls_base aliased its struct pthread — which "worked"
+ * only while __musl_tp was the program's sole TLS variable, sitting at
+ * offset 0 over the self field; any module with real TLS (the C++
+ * runtime, #139) broke it and corrupted the struct.
+ * __wasm_init_tls / __builtin_wasm_tls_{size,align} resolve against the
+ * linker-synthesized TLS globals of the FINAL module, so precompiled musl
+ * picks up each program's actual TLS layout. */
+extern void __wasm_init_tls(void *);
+static void *__wasm_tls_block(struct pthread *td)
+{
+	uintptr_t a = __builtin_wasm_tls_align();
+	if (!a) a = sizeof(void *);
+	return (void *)(((uintptr_t)td - __builtin_wasm_tls_size()) & -a);
+}
+#define WASM_CHILD_TLS_INIT(args) do { \
+	__wasm_init_tls(__wasm_tls_block((args)->td)); \
+	__set_thread_area((args)->td); \
+} while (0)
