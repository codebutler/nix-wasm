diff --git a/src/stdio/__fdopen.c b/src/stdio/__fdopen.c
index 116e78e..5024f9c 100644
--- a/src/stdio/__fdopen.c
+++ b/src/stdio/__fdopen.c
@@ -30,8 +30,15 @@ FILE *__fdopen(int fd, const char *mode)
 	if (strchr(mode, 'e')) __syscall(SYS_fcntl, fd, F_SETFD, FD_CLOEXEC);
 
 	/* Set append mode on fd if opened for append */
+	/* pc (linux-wasm) patch: pad fcntl to the kernel's 3-arg arity. On
+	 * wasm, syscalls are typed indirect calls — a 2-arg call site into
+	 * 3-arg sys_fcntl64 is a signature mismatch → kernel-mode trap →
+	 * "Aiee" panic (every fopen(…, "a") hit this). Same pad applied to
+	 * the other 2-arg fcntl probes (dup2, fchmod/fchown/fchdir,
+	 * posix_spawn), 3-arg openat (fchmodat), 4-arg ppoll (pause),
+	 * 0-arg exit (__unmapself), 5-arg ptrace. */
 	if (*mode == 'a') {
-		int flags = __syscall(SYS_fcntl, fd, F_GETFL);
+		int flags = __syscall(SYS_fcntl, fd, F_GETFL, 0);
 		if (!(flags & O_APPEND))
 			__syscall(SYS_fcntl, fd, F_SETFL, flags | O_APPEND);
 		f->flags |= F_APP;
