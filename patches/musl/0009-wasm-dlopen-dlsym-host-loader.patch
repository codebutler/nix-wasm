diff -ruN a/src/ldso/wasm/dlclose.c b/src/ldso/wasm/dlclose.c
--- a/src/ldso/wasm/dlclose.c	1970-01-01 00:00:00.000000000 +0000
+++ b/src/ldso/wasm/dlclose.c	2026-07-01 20:26:22.697396408 +0000
@@ -0,0 +1,13 @@
+#include <dlfcn.h>
+#include "dynlink.h"
+
+/* wasm dlclose (nix-wasm #130, Track 0 §5): wasm function-table slots cannot
+ * be reclaimed and module instances are engine objects with no unload
+ * operation, so modules intentionally live until exec (leak-until-exit).
+ * Report success — the POSIX contract permits a no-op close, and GModule
+ * treats a failing dlclose as an error worth surfacing. */
+
+int dlclose(void *p)
+{
+	return 0;
+}
diff -ruN a/src/ldso/wasm/dlopen.c b/src/ldso/wasm/dlopen.c
--- a/src/ldso/wasm/dlopen.c	1970-01-01 00:00:00.000000000 +0000
+++ b/src/ldso/wasm/dlopen.c	2026-07-01 20:26:51.941635394 +0000
@@ -0,0 +1,100 @@
+#include <dlfcn.h>
+#include <fcntl.h>
+#include <stdlib.h>
+#include <unistd.h>
+#include <sys/stat.h>
+#include "dynlink.h"
+
+/* wasm dlopen (nix-wasm #126 Track C / #130).
+ *
+ * On the wasm guest a "shared library" is a PIC dylink SIDE_MODULE and
+ * loading one is a host/engine operation (instantiate against the process's
+ * Memory + shared function table; GOT resolution; ctors) — code lives outside
+ * linear memory, so the libc cannot map it itself. The split of labor:
+ *
+ *   guest (this file): open+read the file (the guest FS — 9P, squashfs,
+ *     initramfs — just works), __wasm_dl_probe the image's dylink.0
+ *     requirements, allocate the module's DATA region from the process's own
+ *     malloc arena (the allocator owns the address space), then hand both to
+ *     __wasm_dlopen.
+ *   host (runtime/dylink.js via kernel-worker.js): parse/instantiate/link,
+ *     table bookkeeping, fork/clone replay.
+ *
+ * Handles are small positive integers from the host loader (1 = the main
+ * program, as returned for dlopen(NULL)); they are process-global, which is
+ * exactly what fork/clone replay reproduces. The module's data allocation and
+ * its file-image buffer are intentionally never freed: wasm table slots can't
+ * be reclaimed, so modules live until exec (see dlclose.c).
+ */
+
+#define malloc __libc_malloc
+#define free __libc_free
+
+int __wasm_dl_probe(const void *, unsigned long, unsigned int *);
+long __wasm_dlopen(const void *, unsigned long, void *, int);
+
+void *dlopen(const char *file, int mode)
+{
+	void *buf = 0, *mem = 0, *ret = 0;
+	int fd;
+	struct stat st;
+	off_t got = 0;
+	unsigned int info[3];
+	long h;
+
+	if (!file) {
+		h = __wasm_dlopen(0, 0, 0, mode);
+		return h > 0 ? (void *)h : 0;
+	}
+
+	fd = open(file, O_RDONLY|O_CLOEXEC);
+	if (fd < 0) {
+		__dl_seterr("Error loading shared library %s: cannot open file", file);
+		return 0;
+	}
+	if (fstat(fd, &st) || st.st_size <= 0) {
+		__dl_seterr("Error loading shared library %s: cannot stat file", file);
+		goto out;
+	}
+	buf = malloc(st.st_size);
+	if (!buf) {
+		__dl_seterr("Error loading shared library %s: out of memory", file);
+		goto out;
+	}
+	while (got < st.st_size) {
+		ssize_t r = read(fd, (char *)buf + got, st.st_size - got);
+		if (r <= 0) {
+			__dl_seterr("Error loading shared library %s: read failed", file);
+			goto out;
+		}
+		got += r;
+	}
+	if (__wasm_dl_probe(buf, st.st_size, info)) {
+		__dl_seterr("Error loading shared library %s: not a wasm dylink module", file);
+		goto out;
+	}
+	/* info = { memSize, memAlign (log2), tableSize }. The data region must
+	 * come from OUR arena so the module's addresses are ordinary process
+	 * addresses (and survive a fork's memory copy). */
+	if (info[0]) {
+		size_t align = (size_t)1 << info[1];
+		if (align < 16) align = 16;
+		mem = aligned_alloc(align, (info[0] + align - 1) & ~(align - 1));
+		if (!mem) {
+			__dl_seterr("Error loading shared library %s: out of memory", file);
+			goto out;
+		}
+	}
+	h = __wasm_dlopen(buf, st.st_size, mem, mode);
+	if (h > 0) {
+		ret = (void *)h;
+		mem = 0; /* owned by the module now */
+	} else {
+		__dl_seterr("Error loading shared library %s: link failed (%ld)", file, -h);
+	}
+out:
+	close(fd);
+	free(buf);
+	free(mem);
+	return ret;
+}
diff -ruN a/src/ldso/wasm/dlsym.c b/src/ldso/wasm/dlsym.c
--- a/src/ldso/wasm/dlsym.c	1970-01-01 00:00:00.000000000 +0000
+++ b/src/ldso/wasm/dlsym.c	2026-07-01 20:26:51.944019162 +0000
@@ -0,0 +1,34 @@
+#include <dlfcn.h>
+#include "dynlink.h"
+
+/* wasm dlsym (nix-wasm #126 Track C / #130): a symbol's "address" comes from
+ * the host loader — a data address, or a function-table index (which IS the C
+ * function-pointer representation on wasm). Under the fpcast-emu post-link
+ * pass the host returns the symbol's canonical-thunk elem slot (see the
+ * dynsym-inject build seam), so the pointer is callable through fpcast'd
+ * call_indirect sites — the reason resolution lives host-side against the
+ * module's OWN table layout rather than in a guest symbol walk.
+ *
+ * dlfcn.h __REDIRs dlsym to __dlsym_time64 on time64 archs (wasm is one), so
+ * alias both; RTLD_NEXT (-1) is not supported on this single-namespace
+ * loader and reports "not found". */
+
+long __wasm_dlsym(long, const char *);
+
+static void *wasm_dlsym(void *restrict p, const char *restrict s)
+{
+	long r;
+	if (p == RTLD_NEXT) {
+		__dl_seterr("RTLD_NEXT not supported on wasm");
+		return 0;
+	}
+	r = __wasm_dlsym((long)p, s);
+	if (!r) {
+		__dl_seterr("Symbol not found: %s", s);
+		return 0;
+	}
+	return (void *)r;
+}
+
+weak_alias(wasm_dlsym, dlsym);
+weak_alias(wasm_dlsym, __dlsym_time64);
