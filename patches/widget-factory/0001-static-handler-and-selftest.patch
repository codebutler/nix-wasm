+/* nix-wasm #130 headless gate — the REAL GModule path (no add_callback_symbol
+   workaround). The full widget-factory window needs a Wayland display (no
+   compositor in the node harness), so it is a MANUAL browser check; this
+   --selftest proves the SAME mechanism display-free: GtkBuilder signal
+   autoconnect resolving a .ui <signal> handler BY NAME through
+   gtk_builder_connect_signals(builder, NULL) -> GModule -> g_module_open(NULL) ->
+   musl dlopen(NULL)/dlsym. That path was the #33 wall (dlopen was stubbed -> NULL
+   -> "requires working GModule"); Track C (#130) makes dlopen(NULL)/dlsym real
+   (musl patch 0009 + the runtime side-module loader), and the dynsym-inject seam
+   gives every exported function a canonical-thunk elem slot so the returned
+   &handler is fpcast-correct. So the handler is NOT registered in the callback
+   scope -- it MUST be found via GModule for the emit to fire. Uses a GtkTextBuffer
+   (a non-widget GObject) so no display is required. */
+static int wf_selftest_ran = 0;
+void wf_on_buf_changed (GtkTextBuffer *buffer, gpointer user_data);
+void wf_on_buf_changed (GtkTextBuffer *buffer, gpointer user_data)
+{
+  (void) buffer; (void) user_data;
+  wf_selftest_ran = 1;
+}
+
+static int
+run_selftest (void)
+{
+  static const char *ui =
+    "<interface>"
+    "  <object class=\"GtkTextBuffer\" id=\"buf\">"
+    "    <signal name=\"changed\" handler=\"wf_on_buf_changed\"/>"
+    "  </object>"
+    "</interface>";
+  GtkBuilder *builder;
+  GObject *buf;
+  GError *err = NULL;
+  int have_buf, parsed, ok;
+
+  /* Register GtkTextBuffer's type without a display (no gtk_init). */
+  g_type_class_ref (GTK_TYPE_TEXT_BUFFER);
+
+  builder = gtk_builder_new ();
+  parsed = gtk_builder_add_from_string (builder, ui, -1, &err);
+  if (!parsed)
+    {
+      fprintf (stderr, "widget-factory selftest: builder parse failed: %s\n",
+               err ? err->message : "unknown");
+      g_clear_error (&err);
+      return 1;
+    }
+  /* The #130 proof: NO add_callback_symbol. connect_signals(NULL) must resolve
+     "wf_on_buf_changed" via GModule -> dlopen(NULL)/dlsym -- the real path, now
+     that dlopen works. (Pre-#130 this aborted with "requires working GModule".) */
+  gtk_builder_connect_signals (builder, NULL);
+
+  buf = gtk_builder_get_object (builder, "buf");
+  have_buf = GTK_IS_TEXT_BUFFER (buf);
+  if (have_buf)
+    gtk_text_buffer_set_text (GTK_TEXT_BUFFER (buf), "hi", -1); /* emits "changed" */
+
+  ok = have_buf && wf_selftest_ran && gtk_get_major_version () == 3;
+  printf ("WIDGET-FACTORY-SELFTEST: buf=%d connected_via_gmodule=%d handler_ran=%d major=%u %s\n",
+          have_buf, ok, wf_selftest_ran, gtk_get_major_version (), ok ? "OK" : "FAIL");
+  fflush (stdout);
+  g_object_unref (builder);
+  return ok ? 0 : 1;
+}
+
