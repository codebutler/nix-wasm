# wasm-nixpkgs-channel.nix — the in-guest "channel" that lets the guest evaluate
# (and attempt to install) ANY nixpkgs package against the wasm crossSystem,
# instead of only the 4-entry curated catalog (binary-cache.nix `pkgs.nix`).
#
# WHY this is coherent (the key insight): `wasm-cross.nix` takes an explicit
# `localSystem` and the cross derivations are host-agnostic, so EVAL is pure and
# architecture-independent. If the guest imports nixpkgs with `localSystem` PINNED
# to the build host (x86_64-linux — the CI/publish host), it computes the SAME
# `cross.<pkg>` .drv hashes the host builds, then substitutes the host's prebuilt
# output. Proven in-guest: `cross.hello` / `cross.file` evaluate to wasm32 .drvs in
# ~15s within the ~2 GiB cap (docs/superpowers/notes/2026-06-28-nixpkgs-in-guest-eval.md).
#
# Design (no kernel/ABI change — reuses the existing nix-cache substitution path):
#   • This derivation is a SMALL store path: the cross config (`wasm-cross.nix`,
#     `deps-overlay.nix`, `toolchain/`, `patches/`, `userspace/`) + a generated
#     `default.nix`. Its closure deliberately does NOT contain the ~470 MB nixpkgs
#     source — `default.nix` reaches nixpkgs via the `<nixpkgs>` NIX_PATH lookup,
#     NOT an absolute store-path reference, so a plain `nix-env -iA guest-cc` does
#     not drag nixpkgs in. nixpkgs is published to the cache separately and
#     substituted lazily only when a *nixpkgs* attribute is actually evaluated
#     (the guest's nix.conf `nix-path = nixpkgs=<store path>` resolves `<nixpkgs>`).
#   • The returned set is `cross` EXTENDED with the 4 on-demand toolchain packages
#     (guest-cc/guest-cxx/guest-clang/make-wasm32) under the names the existing
#     `nix-env -iA <name>` flow + CI smokes use, so making the channel the default
#     expr does not regress those. Attribute access is lazy: `nix-env -iA guest-cc`
#     reads the `//` right-hand side and never forces `cross` (so no nixpkgs eval);
#     only `nix-env -iA file` / `-qaP` evaluate the nixpkgs side.
#
# self      — the flake source (for the cross config files; `${self}/toolchain`…)
# nixpkgs   — the pinned nixpkgs source store path (referenced by the generated
#             default.nix only via <nixpkgs>; baked into system.nix's nix-path)
# localSystem — the build/publish host system, pinned so guest .drv hashes match
# tools     — { "guest-cc" = …; "guest-cxx" = …; "guest-clang" = …; "make-wasm32" = …; }
{ pkgs, self, localSystem, tools }:
let
  toolsNix = pkgs.lib.concatStringsSep "\n"
    (pkgs.lib.mapAttrsToList (name: drv: ''  "${name}" = builtins.storePath "${drv}";'') tools);
in
pkgs.runCommand "wasm-nixpkgs-channel" { } ''
  mkdir -p $out
  cp -r ${self}/toolchain ${self}/patches ${self}/userspace $out/
  cp ${self}/wasm-cross.nix ${self}/deps-overlay.nix $out/
  chmod -R u+w $out

  cat > $out/default.nix <<NIXEOF
  # GENERATED by userspace/wasm-nixpkgs-channel.nix — the guest's nix-env default
  # expression. Returns the wasm cross package set + the on-demand toolchain.
  { system ? "${localSystem}" }:
  let
    # <nixpkgs> resolves via the guest nix.conf nix-path (baked in system.nix) and
    # is substituted lazily — only forced when a nixpkgs attribute is evaluated.
    nixpkgs = <nixpkgs>;
    pkgs = import nixpkgs { inherit system; };
    compilerRt = import ./toolchain/compiler-rt.nix { inherit pkgs; };
    musl = import ./toolchain/musl.nix { inherit pkgs compilerRt; };
    kernelHeaders = import ./toolchain/kernel-headers.nix { inherit pkgs; };
    libcxx = import ./toolchain/libcxx.nix { inherit pkgs musl kernelHeaders compilerRt; };
    sysroot = import ./toolchain/sysroot.nix { inherit pkgs musl kernelHeaders; };
    cross = import ./wasm-cross.nix {
      inherit nixpkgs sysroot compilerRt libcxx;
      localSystem = system;
      overlays = [ (import ./deps-overlay.nix { inherit kernelHeaders; muslWasm = musl; }) ];
    };
  in
  cross // {
  ${toolsNix}
  }
  NIXEOF
''
