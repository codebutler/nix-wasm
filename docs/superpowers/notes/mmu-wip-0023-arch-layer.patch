+++ b/arch/wasm/mm/fault.c
@@ -0,0 +1,94 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Software-MMU fault entry (#128 A2). The instrumented user code's EXTENDED
+ * translate variant calls env.__mmu_fault(addr, kind) on a not-present or
+ * permission miss; the engine routes it here on the faulting task's kernel
+ * context (the same shape as a syscall entry). We resolve through the generic
+ * MM — demand paging, COW, stack growth, mprotect — and return 0 to RETRY the
+ * translate, or queue the fatal signal and return nonzero (the engine then
+ * lets the normal signal path run instead of retrying).
+ *
+ * A1 boots do not call this (the fast-path translate has no present check and
+ * every VMA is VM_LOCKED-populated at creation); it is compiled in so the
+ * kernel side of A2 is complete and gate-able.
+ */
+#include <linux/mm.h>
+#include <linux/sched/signal.h>
+#include <linux/ptrace.h>
+#include <linux/sched/task_stack.h>
+
+#define WASM_MMU_FAULT_READ	0U
+#define WASM_MMU_FAULT_WRITE	1U
+#define WASM_MMU_FAULT_EXEC	2U
+
+asmlinkage unsigned long __wasm_mmu_fault(unsigned long addr,
+					  unsigned long kind);
+asmlinkage unsigned long __wasm_mmu_fault(unsigned long addr,
+					  unsigned long kind)
+{
+	struct mm_struct *mm = current->mm;
+	struct vm_area_struct *vma;
+	unsigned int flags = FAULT_FLAG_DEFAULT | FAULT_FLAG_USER;
+	vm_fault_t fault;
+
+	if (!mm || addr >= TASK_SIZE)
+		goto bad_area_nosemaphore;
+
+	if (kind == WASM_MMU_FAULT_WRITE)
+		flags |= FAULT_FLAG_WRITE;
+	else if (kind == WASM_MMU_FAULT_EXEC)
+		flags |= FAULT_FLAG_INSTRUCTION;
+
+retry:
+	vma = lock_mm_and_find_vma(mm, addr, current_pt_regs());
+	if (!vma)
+		goto bad_area_nosemaphore;
+
+	if (kind == WASM_MMU_FAULT_WRITE) {
+		if (!(vma->vm_flags & VM_WRITE))
+			goto bad_area;
+	} else if (kind == WASM_MMU_FAULT_EXEC) {
+		if (!(vma->vm_flags & VM_EXEC))
+			goto bad_area;
+	} else {
+		if (!(vma->vm_flags & (VM_READ | VM_WRITE | VM_EXEC)))
+			goto bad_area;
+	}
+
+	fault = handle_mm_fault(vma, addr, flags, current_pt_regs());
+
+	if (fault_signal_pending(fault, current_pt_regs()))
+		return 1;
+
+	/* The fault is fully completed (including releasing mmap lock) */
+	if (fault & VM_FAULT_COMPLETED)
+		return 0;
+
+	if (unlikely(fault & VM_FAULT_RETRY)) {
+		flags |= FAULT_FLAG_TRIED;
+		goto retry;
+	}
+
+	mmap_read_unlock(mm);
+
+	if (unlikely(fault & VM_FAULT_ERROR)) {
+		if (fault & VM_FAULT_OOM) {
+			pagefault_out_of_memory();
+			return 1;
+		}
+		if (fault & (VM_FAULT_SIGBUS | VM_FAULT_HWPOISON |
+			     VM_FAULT_HWPOISON_LARGE)) {
+			force_sig_fault(SIGBUS, BUS_ADRERR, (void __user *)addr);
+			return 1;
+		}
+		goto bad_area_nosemaphore;
+	}
+
+	return 0;
+
+bad_area:
+	mmap_read_unlock(mm);
+bad_area_nosemaphore:
+	force_sig_fault(SIGSEGV, SEGV_MAPERR, (void __user *)addr);
+	return 1;
+}
