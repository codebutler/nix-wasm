+static int parse_dylink0_meminfo(char *p, char *end,
+		unsigned int *data_size, unsigned int *data_align,
+		unsigned int *table_size, unsigned int *table_align)
+{
+	u8 subsection_id;
+	unsigned int subsection_length;
+	char *subsection_end;
+
+	for (;;) {
+		if (p == end) {
+			pr_err("No dylink.0 subsection id");
+			return -ENOEXEC;
+		}
+		subsection_id = *(u8 *)(p++);
+
+		if (!wasm_consume_varU32(&p, &subsection_length,
+				min_t(unsigned long, 5UL, end - p))) {
+			pr_err("Failed to read dylink.0 subsection length");
+			return -ENOEXEC;
+		}
+		subsection_end = p + subsection_length;
+		if (subsection_end < p || subsection_end > end) {
+			pr_err("dylink.0 subsection length overflow");
+			return -ENOEXEC;
+		}
+
+		if (subsection_id == WASM_DYLINK_MEMINFO) {
+			if (!wasm_consume_varU32(&p, data_size,
+					min_t(unsigned long, 5UL, subsection_end - p)))
+				return -ENOEXEC;
+			*data_size = PAGE_ALIGN(*data_size);
+			if (!wasm_consume_varU32(&p, data_align,
+					min_t(unsigned long, 5UL, subsection_end - p))
+					|| *data_align > 31U)
+				return -ENOEXEC;
+			*data_align = 1UL << (int)*data_align;
+			if (!wasm_consume_varU32(&p, table_size,
+					min_t(unsigned long, 5UL, subsection_end - p)))
+				return -ENOEXEC;
+			*table_size = PAGE_ALIGN(*table_size);
+			if (!wasm_consume_varU32(&p, table_align,
+					min_t(unsigned long, 5UL, subsection_end - p))
+					|| *table_align > 31U)
+				return -ENOEXEC;
+			*table_align = 1UL << (int)*table_align;
+			return 0;
+		}
+
