@@ -0,0 +1,127 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Software-MMU uaccess (#128): kernel<->user copies walk the user page table.
+ * The kernel is identity-mapped (phys); a user va resolves through the
+ * current mm's 2-level table (asm/pgtable.h). An unmapped/absent page is a
+ * fault -> return the remaining byte count, exactly the raw_copy contract.
+ * (A2 will route the miss through handle_mm_fault for demand paging/COW;
+ * A1 exec populates the table up front, so a miss here is a real EFAULT.)
+ */
+#include <linux/mm.h>
+#include <linux/sched.h>
+#include <linux/string.h>
+#include <linux/export.h>
+#include <asm/pgtable.h>
+#include <linux/uaccess.h>
+
+/* On a soft-walk miss, fault the page in through the generic MM (demand
+ * paging, COW, stack growth) and retry — the software analog of a hardware
+ * uaccess fault + fixup. fixup_user_fault is the standard API (futex uses it).
+ */
+static bool user_fault_in(unsigned long va, bool write)
+{
+	struct mm_struct *mm = current->mm;
+	unsigned int flags = FAULT_FLAG_KILLABLE | (write ? FAULT_FLAG_WRITE : 0);
+	int ret;
+
+	if (!mm)
+		return false;
+	mmap_read_lock(mm);
+	ret = fixup_user_fault(mm, va, flags, NULL);
+	mmap_read_unlock(mm);
+	return ret == 0;
+}
+
+/* Resolve one user page; returns false if unmapped/not-present (or, for
+ * writes, write-protected). *phys gets the physical byte address of va. */
+static bool user_page_phys(unsigned long va, bool write, unsigned long *phys)
+{
+	struct mm_struct *mm = current->mm;
+	pgd_t *pgd;
+	p4d_t *p4d;
+	pud_t *pud;
+	pmd_t *pmd;
+	pte_t *pte;
+
+	if (!mm || va >= TASK_SIZE)
+		return false;
+	pgd = pgd_offset(mm, va);
+	if (pgd_none(*pgd) || pgd_bad(*pgd))
+		return false;
+	p4d = p4d_offset(pgd, va);
+	if (p4d_none(*p4d))
+		return false;
+	pud = pud_offset(p4d, va);
+	if (pud_none(*pud))
+		return false;
+	pmd = pmd_offset(pud, va);
+	if (pmd_none(*pmd) || pmd_bad(*pmd))
+		return false;
+	pte = pte_offset_kernel(pmd, va);
+	if (!pte_present(*pte))
+		return false;
+	if (write && !pte_write(*pte))
+		return false;
+	*phys = (pte_val(*pte) & PAGE_MASK) + (va & ~PAGE_MASK);
+	return true;
+}
+
+/* Copy n bytes across the user boundary, page by page. dir_to_user picks the
+ * direction; returns the number of bytes NOT copied (0 = full success). */
+static unsigned long walk_copy(void *kaddr, unsigned long uva, unsigned long n,
+			       bool to_user)
+{
+	while (n) {
+		unsigned long phys;
+		unsigned long chunk = min(n, PAGE_SIZE - (uva & ~PAGE_MASK));
+
+		if (!user_page_phys(uva, to_user, &phys)) {
+			if (!user_fault_in(uva, to_user) ||
+			    !user_page_phys(uva, to_user, &phys))
+				return n;
+		}
+		if (to_user)
+			memcpy((void *)phys, kaddr, chunk);
+		else
+			memcpy(kaddr, (void *)phys, chunk);
+		kaddr += chunk;
+		uva += chunk;
+		n -= chunk;
+	}
+	return 0;
+}
+
+unsigned long raw_copy_from_user(void *to, const void __user *from,
+				 unsigned long n)
+{
+	return walk_copy(to, (unsigned long)from, n, false);
+}
+EXPORT_SYMBOL(raw_copy_from_user);
+
+unsigned long raw_copy_to_user(void __user *to, const void *from,
+			       unsigned long n)
+{
+	return walk_copy((void *)from, (unsigned long)to, n, true);
+}
+EXPORT_SYMBOL(raw_copy_to_user);
+
+unsigned long __clear_user(void __user *to, unsigned long n)
+{
+	unsigned long uva = (unsigned long)to;
+
+	while (n) {
+		unsigned long phys;
+		unsigned long chunk = min(n, PAGE_SIZE - (uva & ~PAGE_MASK));
+
+		if (!user_page_phys(uva, true, &phys)) {
+			if (!user_fault_in(uva, true) ||
+			    !user_page_phys(uva, true, &phys))
+				return n;
+		}
+		memset((void *)phys, 0, chunk);
+		uva += chunk;
+		n -= chunk;
+	}
+	return 0;
+}
+EXPORT_SYMBOL(__clear_user);
